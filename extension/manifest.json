{
  "manifest_version": 3,
  "name": "MarkIt - 书签管理器",
  "version": "1.0.0",
  "description": "一款本地功能丰富的书签管理器，自动归类，多视图切换，支持搜索、收藏、稍后阅读。",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
